{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://35.232.241.155:8080/api/:path*"
    },
    {
      "source": "/edge/:path*",
      "destination": "https://edge-placeholder-update-after-tunnel.invalid/edge/:path*"
    },
    {
      "source": "/((?!api|edge).*)",
      "destination": "/index.html"
    }
  ]
}
